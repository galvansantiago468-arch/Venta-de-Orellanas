@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: rgb(51, 51, 51); background: linear-gradient(135deg, rgb(245, 247, 250) 0%, rgb(232, 245, 233) 100%); min-height: 100vh; }

.container { max-width: 1200px; margin: 0px auto; padding: 0px 20px; }

header { background: linear-gradient(135deg, rgb(46, 125, 50) 0%, rgb(85, 139, 47) 100%); color: white; padding: 60px 20px; text-align: center; box-shadow: rgba(0, 0, 0, 0.1) 0px 4px 20px; position: relative; overflow: hidden; }

header::before { content: ""; position: absolute; inset: 0px; background: url("data:image/svg+xml,<svg width=\"100\" height=\"100\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"50\" cy=\"50\" r=\"2\" fill=\"rgba(255,255,255,0.1)\"/></svg>"); opacity: 0.3; }

header h1 { font-size: 3.5em; margin-bottom: 15px; font-weight: 700; text-shadow: rgba(0, 0, 0, 0.2) 2px 2px 4px; position: relative; z-index: 1; }

header p { font-size: 1.3em; opacity: 0.95; position: relative; z-index: 1; max-width: 600px; margin: 0px auto; }

.mushroom-icon { font-size: 2em; margin: 0px 10px; display: inline-block; animation: 3s ease-in-out 0s infinite normal none running float; }

@keyframes float { 
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

.products-section { padding: 80px 20px; }

.section-title { text-align: center; font-size: 2.5em; color: rgb(46, 125, 50); margin-bottom: 50px; font-weight: 700; }

.products-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 40px; margin-bottom: 60px; }

.product-card { background: white; border-radius: 20px; padding: 40px 30px; text-align: center; box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 30px; transition: 0.4s; position: relative; overflow: hidden; }

.product-card::before { content: ""; position: absolute; top: 0px; left: 0px; right: 0px; height: 5px; background: linear-gradient(90deg, rgb(46, 125, 50), rgb(85, 139, 47), rgb(104, 159, 56)); transform: scaleX(0); transition: transform 0.4s; }

.product-card:hover { transform: translateY(-10px); box-shadow: rgba(0, 0, 0, 0.15) 0px 20px 40px; }

.product-card:hover::before { transform: scaleX(1); }

.product-icon { font-size: 5em; margin-bottom: 20px; display: inline-block; filter: drop-shadow(rgba(0, 0, 0, 0.1) 0px 4px 6px); transition: transform 0.3s; }

.product-card:hover .product-icon { transform: scale(1.1) rotate(5deg); }

.product-name { font-size: 1.8em; color: rgb(46, 125, 50); margin-bottom: 10px; font-weight: 700; }

.product-weight { font-size: 2.5em; color: rgb(85, 139, 47); font-weight: 800; margin: 15px 0px; text-shadow: rgba(0, 0, 0, 0.05) 2px 2px 4px; }

.product-description { color: rgb(102, 102, 102); margin: 20px 0px; font-size: 1.05em; line-height: 1.6; min-height: 60px; }

.product-button { background: linear-gradient(135deg, rgb(46, 125, 50) 0%, rgb(85, 139, 47) 100%); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 15px 35px; font-size: 1.1em; border-radius: 50px; cursor: pointer; transition: 0.3s; font-weight: 600; box-shadow: rgba(46, 125, 50, 0.3) 0px 4px 15px; margin-top: 10px; }

.product-button:hover { transform: scale(1.05); box-shadow: rgba(46, 125, 50, 0.4) 0px 6px 20px; background: linear-gradient(135deg, rgb(27, 94, 32) 0%, rgb(51, 105, 30) 100%); }

.product-button:active { transform: scale(0.98); }

.benefits-section { background: white; padding: 80px 20px; box-shadow: rgba(0, 0, 0, 0.05) 0px -5px 20px; }

.benefits-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 40px; margin-top: 40px; }

.benefit-card { text-align: center; padding: 30px; border-radius: 15px; background: linear-gradient(135deg, rgb(241, 248, 233) 0%, rgb(232, 245, 233) 100%); transition: 0.3s; }

.benefit-card:hover { transform: translateY(-5px); box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 25px; }

.benefit-icon { font-size: 3.5em; margin-bottom: 15px; display: inline-block; }

.benefit-title { font-size: 1.5em; color: rgb(46, 125, 50); margin-bottom: 10px; font-weight: 700; }

.benefit-description { color: rgb(85, 85, 85); font-size: 1.05em; line-height: 1.6; }

footer { background: linear-gradient(135deg, rgb(27, 94, 32) 0%, rgb(46, 125, 50) 100%); color: white; padding: 50px 20px; text-align: center; }

.footer-content { max-width: 800px; margin: 0px auto; }

.footer-title { font-size: 2em; margin-bottom: 20px; font-weight: 700; }

.contact-info { display: flex; flex-wrap: wrap; justify-content: center; gap: 30px; margin-top: 30px; }

.contact-item { display: flex; align-items: center; gap: 10px; font-size: 1.1em; }

.contact-icon { font-size: 1.5em; }

.footer-bottom { margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.2); opacity: 0.8; }

@media (max-width: 768px) {
  header h1 { font-size: 2.5em; }
  header p { font-size: 1.1em; }
  .section-title { font-size: 2em; }
  .products-grid { grid-template-columns: 1fr; gap: 30px; }
  .product-weight { font-size: 2em; }
  .contact-info { flex-direction: column; gap: 15px; }
}

@keyframes fadeInUp { 
  0% { opacity: 0; transform: translateY(30px); }
  100% { opacity: 1; transform: translateY(0px); }
}

.product-card { animation: 0.6s ease 0s 1 normal forwards running fadeInUp; }

.product-card:nth-child(1) { animation-delay: 0.1s; }

.product-card:nth-child(2) { animation-delay: 0.2s; }

.product-card:nth-child(3) { animation-delay: 0.3s; }
